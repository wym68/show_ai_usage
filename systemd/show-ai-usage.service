[Unit]
Description=Show AI Usage — Poll subscription usage data
Documentation=https://github.com/your/project
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Provider credentials (KIMI_CODE_ACCESS_TOKEN, MINIMAX_API_KEY, ...) are
# read env-first. The leading "-" makes the file optional so the unit still
# starts if it is absent.
EnvironmentFile=-%h/.config/show-ai-usage/secrets.env
ExecStart=@@UV_PATH@@ run --directory @@PROJECT_DIR@@ python -m poller.main --oneshot
WorkingDirectory=@@PROJECT_DIR@@
User=%u
Restart=on-failure
RestartSec=60
StandardOutput=journal
StandardError=journal
